# ══════════════════════════════════════════════════════════════════════════════
# SWE Agent — Local Development .env
# Generated for local run (API/worker outside Docker, Redis/Postgres in Docker)
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG
LOG_FORMAT=console
WORKER_CONCURRENCY=1

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-dev-placeholder-key
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_TIMEOUT_SECONDS=120
ANTHROPIC_MAX_RETRIES=3

# ── LangSmith Observability ───────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls-dev-placeholder
LANGCHAIN_PROJECT=swe-agent-dev
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_dev_placeholder_token
GITHUB_WEBHOOK_SECRET=dev-webhook-secret-local-only
GITHUB_BOT_USERNAME=swe-agent[bot]
GITHUB_PR_LABEL=automated-pr

# ── Database (matches docker-compose.dev.yml) ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dev_user:dev_pass@localhost:5432/swe_agent_dev
POSTGRES_USER=dev_user
POSTGRES_PASSWORD=dev_pass
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=true

# ── Redis (localhost since API runs outside Docker) ───────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_JOB_TIMEOUT=1800
REDIS_RESULT_TTL=86400

# ── Docker Sandbox ───────────────────────────────────────────────────────────
SANDBOX_IMAGE=swe-agent-sandbox:latest
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_QUOTA=50000
SANDBOX_TIMEOUT_SECONDS=120
SANDBOX_NETWORK_DISABLED=true

# ── Agent ────────────────────────────────────────────────────────────────────
AGENT_MAX_RETRIES=3
AGENT_MAX_FILES_IN_CONTEXT=10
AGENT_MAX_CONTEXT_TOKENS=100000
AGENT_PR_DRAFT_ON_FAILURE=true

# ── App Secret ───────────────────────────────────────────────────────────────
APP_SECRET_KEY=dev-secret-key-not-for-production-use
