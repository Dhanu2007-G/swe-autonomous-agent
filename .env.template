# ══════════════════════════════════════════════════════════════════════════════
# SWE Agent — Environment Configuration Template
# Copy to .env and fill in real values. NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production                          # development | staging | production
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                            # json | console
WORKER_CONCURRENCY=3

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...         # REQUIRED — get from console.anthropic.com
ANTHROPIC_MODEL=claude-opus-4-6         # Model to use for all nodes
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_TIMEOUT_SECONDS=120
ANTHROPIC_MAX_RETRIES=3

# ── OpenAI (optional — for embeddings) ───────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── LangSmith Observability ───────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...                  # get from smith.langchain.com
LANGCHAIN_PROJECT=swe-agent-prod
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...                       # PAT with: repo, issues, pull_requests
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here  # openssl rand -hex 32
GITHUB_BOT_USERNAME=swe-agent[bot]
GITHUB_PR_LABEL=automated-pr

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://swe_agent:CHANGE_ME@postgres:5432/swe_agent
POSTGRES_USER=swe_agent
POSTGRES_PASSWORD=CHANGE_ME              # openssl rand -base64 32
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_JOB_TIMEOUT=1800                   # 30 minutes max per job
REDIS_RESULT_TTL=86400

# ── Docker Sandbox ───────────────────────────────────────────────────────────
SANDBOX_IMAGE=swe-agent-sandbox:latest
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_QUOTA=50000                  # 50% of one CPU
SANDBOX_TIMEOUT_SECONDS=120
SANDBOX_NETWORK_DISABLED=true

# ── Agent ────────────────────────────────────────────────────────────────────
AGENT_MAX_RETRIES=3
AGENT_MAX_FILES_IN_CONTEXT=10
AGENT_MAX_CONTEXT_TOKENS=100000
AGENT_PR_DRAFT_ON_FAILURE=true

# ── Observability ────────────────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317  # Optional
PROMETHEUS_PORT=9090
GRAFANA_PASSWORD=CHANGE_ME

# ── App Secret ───────────────────────────────────────────────────────────────
APP_SECRET_KEY=CHANGE_ME                 # openssl rand -hex 32
